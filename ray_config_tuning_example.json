{
  "training": {
    "batch_size": 128,
    "num_train_batches": 2,
    "lr": "tune.loguniform(1e-4, 5e-3)",
    "gamma": "tune.uniform(0.90, 0.99)",
    "num_steps_sampled_before_learning_starts": 0,
    "model": {
      "fcnet_hiddens": "tune.choice([[64, 64], [128, 64], [128, 128], [256, 128], [256, 128, 256]])",
      "fcnet_activation": "relu"
    },
    "replay_buffer_config": {
      "type": "MultiAgentReplayBuffer",
      "capacity": 3000,
      "worker_side_prioritization": false
    }
  },
  "evaluation": {
    "evaluation_config": {
      "explore": false,
      "flows_file": "flows_eval.json",
      "is_evaluation": true
    }
  },
  "rollouts": {
    "num_rollout_workers": 1,
    "duration_per_worker": 5,
    "duration_unit": "episodes"
  },
  "callbacks": {
    "callbacks_class": "RL4CC.callbacks.sat_callbacks.SatCallbacks"
  },
  "debugging": {
    "log_level": "ERROR",
    "seed": 36
  }
}